# ============================================================
# GridFlow — 環境変数
# コピーして .env.local を作成してください: cp .env.example .env.local
# ============================================================

# PostgreSQL接続文字列
# Vercel + Vercel Postgres / Neon / Supabase 等を使う場合は発行されたURLをそのまま貼り付け
DATABASE_URL=postgresql://user:password@localhost:5432/gridflow

# JWTセッション署名用のシークレット（32文字以上のランダム文字列）
# 生成例: openssl rand -base64 32
JWT_SECRET=

# 取引所APIキー暗号化用のマスターキー（32バイト = 64文字のhex文字列）
# 生成例: openssl rand -hex 32
ENCRYPTION_KEY=

# 本番デプロイURL（Cookieのsecure属性判定等に使用、任意）
NEXT_PUBLIC_APP_URL=http://localhost:3000
